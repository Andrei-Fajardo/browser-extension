{
  "manifest_version": 3,
  "name": "Mouse Parts Lookup",
  "description": "Look up sourced mouse parts (switches, encoders, sensors, MCUs). Unknown stays blank — no hallucinated specs.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mouse Parts Lookup"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/tesseract/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
